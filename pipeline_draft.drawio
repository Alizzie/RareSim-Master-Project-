        <mxCell id="4mRV1LXF5f9laapuvszc-138" value="&lt;span class=&quot;ͼe&quot;&gt;embeddings&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ8&quot;&gt;=&lt;/span&gt;&lt;span&gt; {&lt;/span&gt;&lt;br&gt;&lt;span&gt;    &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001251&quot;&lt;/span&gt;&lt;span&gt;: &lt;/span&gt;&lt;span class=&quot;ͼe&quot;&gt;np&lt;/span&gt;&lt;span class=&quot;ͼ8&quot;&gt;.&lt;/span&gt;&lt;span&gt;array([&lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.2&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.5&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.1&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.0&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.3&lt;/span&gt;&lt;span&gt;]),  &lt;/span&gt;&lt;span class=&quot;ͼ6&quot;&gt;# Ataxia&lt;/span&gt;&lt;br&gt;&lt;span&gt;    &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001083&quot;&lt;/span&gt;&lt;span&gt;: &lt;/span&gt;&lt;span class=&quot;ͼe&quot;&gt;np&lt;/span&gt;&lt;span class=&quot;ͼ8&quot;&gt;.&lt;/span&gt;&lt;span&gt;array([&lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.3&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.5&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.1&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.0&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.2&lt;/span&gt;&lt;span&gt;]),  &lt;/span&gt;&lt;span class=&quot;ͼ6&quot;&gt;# Ectopia lentis&lt;/span&gt;&lt;br&gt;&lt;span&gt;    &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0002615&quot;&lt;/span&gt;&lt;span&gt;: &lt;/span&gt;&lt;span class=&quot;ͼe&quot;&gt;np&lt;/span&gt;&lt;span class=&quot;ͼ8&quot;&gt;.&lt;/span&gt;&lt;span&gt;array([&lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.2&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.4&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.2&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.1&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.3&lt;/span&gt;&lt;span&gt;]),  &lt;/span&gt;&lt;span class=&quot;ͼ6&quot;&gt;# Aortic root dilation&lt;/span&gt;&lt;br&gt;&lt;span&gt;    &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001106&quot;&lt;/span&gt;&lt;span&gt;: &lt;/span&gt;&lt;span class=&quot;ͼe&quot;&gt;np&lt;/span&gt;&lt;span class=&quot;ͼ8&quot;&gt;.&lt;/span&gt;&lt;span&gt;array([&lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.0&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.1&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.2&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.0&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.1&lt;/span&gt;&lt;span&gt;]),  &lt;/span&gt;&lt;span class=&quot;ͼ6&quot;&gt;# Scoliosis&lt;/span&gt;&lt;br&gt;&lt;span&gt;    &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001382&quot;&lt;/span&gt;&lt;span&gt;: &lt;/span&gt;&lt;span class=&quot;ͼe&quot;&gt;np&lt;/span&gt;&lt;span class=&quot;ͼ8&quot;&gt;.&lt;/span&gt;&lt;span&gt;array([&lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.1&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.2&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.3&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.1&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼb&quot;&gt;0.1&lt;/span&gt;&lt;span&gt;]),  &lt;/span&gt;&lt;span class=&quot;ͼ6&quot;&gt;# Joint hypermobility&lt;/span&gt;&lt;br&gt;&lt;span&gt;}&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span class=&quot;ͼ6&quot;&gt;# --- Patient profile ---&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;ͼe&quot;&gt;patient_hpos&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ8&quot;&gt;=&lt;/span&gt;&lt;span&gt; [&lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001083&quot;&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0002615&quot;&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001382&quot;&lt;/span&gt;&lt;span&gt;]&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span class=&quot;ͼ6&quot;&gt;# --- Disease profiles ---&lt;/span&gt;&lt;br&gt;&lt;span class=&quot;ͼe&quot;&gt;disease_list&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span class=&quot;ͼ8&quot;&gt;=&lt;/span&gt;&lt;span&gt; [&lt;/span&gt;&lt;br&gt;&lt;span&gt;    {&lt;/span&gt;&lt;br&gt;&lt;span&gt;        &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;name&quot;&lt;/span&gt;&lt;span&gt;: &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;Marfan syndrome&quot;&lt;/span&gt;&lt;span&gt;,&lt;/span&gt;&lt;br&gt;&lt;span&gt;        &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;hpo_terms&quot;&lt;/span&gt;&lt;span&gt;: [&lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001083&quot;&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0002615&quot;&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001106&quot;&lt;/span&gt;&lt;span&gt;]&lt;/span&gt;&lt;br&gt;&lt;span&gt;    },&lt;/span&gt;&lt;br&gt;&lt;span&gt;    {&lt;/span&gt;&lt;br&gt;&lt;span&gt;        &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;name&quot;&lt;/span&gt;&lt;span&gt;: &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;Spinocerebellar ataxia&quot;&lt;/span&gt;&lt;span&gt;,&lt;/span&gt;&lt;br&gt;&lt;span&gt;        &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;hpo_terms&quot;&lt;/span&gt;&lt;span&gt;: [&lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001251&quot;&lt;/span&gt;&lt;span&gt;, &lt;/span&gt;&lt;span class=&quot;ͼc&quot;&gt;&quot;HPO:0001106&quot;&lt;/span&gt;&lt;span&gt;]&lt;/span&gt;&lt;br&gt;&lt;span&gt;    }&lt;/span&gt;&lt;br&gt;&lt;span&gt;]&lt;/span&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="2460" y="100" width="410" height="340" as="geometry" />
        </mxCell>
